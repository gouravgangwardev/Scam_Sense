# ─────────────────────────────────────────────
# SCAM SENSE AI — Environment Variables
# ─────────────────────────────────────────────
# NEVER upload this file to GitHub.
# It is already protected by .gitignore.
# ─────────────────────────────────────────────

# ── Flask Secret Key ──────────────────────────
# CRITICAL: Replace this with a real random key before deploying.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE-THIS-WITH-A-REAL-RANDOM-KEY-BEFORE-DEPLOYING

# ── AI Engine ─────────────────────────────────
# Message AI server — analyzes suspicious text messages
MESSAGE_AI_URL=http://localhost:5001/predict

# Link AI server — analyzes suspicious URLs
LINK_AI_URL=http://localhost:5002/predict/url

# Timeout in seconds to wait for AI response
# If AI takes longer than this, fallback kicks in
AI_REQUEST_TIMEOUT=10

# ── Flask Mode ────────────────────────────────
# True  = Development mode (shows errors, auto-reload)
# False = Production mode (MUST be False before deploying)
DEBUG=True

# ── Server ────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── File Upload ───────────────────────────────
# Maximum allowed screenshot size in MB
MAX_FILE_SIZE_MB=5

# ── Input Limits ──────────────────────────────
# Maximum characters allowed in message scan
MAX_MESSAGE_LENGTH=5000

# ── Database ──────────────────────────────────
# Path to SQLite database file
# Do not change unless you move the database folder
DATABASE_PATH=database/scans.db

# ── Rate Limiting ─────────────────────────────
# How many scans one user (IP) can do per minute
RATE_LIMIT_SCAN=10

# ── Upload Folder ─────────────────────────────
# Where screenshots are temporarily saved before OCR
# Do not change unless you move the uploads folder
UPLOAD_FOLDER=uploads
